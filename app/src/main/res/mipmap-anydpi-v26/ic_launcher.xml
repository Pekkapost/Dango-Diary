<?xml version="1.0" encoding="utf-8"?>
<!--
  To swap which dango variant is the active icon, change the foreground reference below to one
  of the three vectors in `res/drawable/`:
    @drawable/ic_launcher_dango_trio   (active — hanami trio on stick)
    @drawable/ic_launcher_dango_face   (single ball with a face)
    @drawable/ic_launcher_dango_book   (trio + open-book ribbon)
  Mirror the same change in `ic_launcher_round.xml` so the rounded launcher mask matches.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_dango_trio" />
</adaptive-icon>
